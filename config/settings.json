// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "bottom_dock_layout": "contained",
  "file_finder": {
    "modal_max_width": "medium"
  },
  "seed_search_query_from_cursor": "selection",
  "use_smartcase_search": true,
  "prettier": {
    "allowed": false
  },
  "semantic_tokens": "off",
  "message_editor": {
    "auto_replace_emoji_shortcode": false
  },
  "image_viewer": {
    "unit": "decimal"
  },
  "colorize_brackets": true,
  "middle_click_paste": false,
  "lsp_document_colors": "background",
  "inlay_hints": {
    "show_background": true,
    "show_type_hints": true,
    "enabled": false
  },
  "completion_detail_alignment": "right",
  "completion_menu_scrollbar": "auto",
  "completions": {
    "words_min_length": 2,
    "words": "enabled"
  },
  "show_whitespaces": "boundary",
  "whitespace_map": {
    "space": "•",
    "tab": ">",
  },
  "always_treat_brackets_as_autoclosed": false,
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "indent_aware",
    "active_line_width": 10,
    "line_width": 2
  },
  "show_wrap_guides": true,
  "hard_tabs": true,
  "inline_code_actions": true,
  "relative_line_numbers": "disabled",
  "drag_and_drop_selection": {
    "delay": 200
  },
  "hover_popover_delay": 200,
  "show_signature_help_after_edits": true,
  "auto_signature_help": true,
  "horizontal_scroll_margin": 5.0,
  "sticky_scroll": {
    "enabled": true
  },
  "diff_view_style": "unified",
  "auto_update": false,
  "on_last_window_closed": "quit_app",
  "when_closing_with_no_tabs": "keep_window_open",
  "session": {
    "trust_all_worktrees": false
  },
  "languages": {
    "GDScript": {
      "hard_tabs": true
    }
  },
  "vim_mode": false,
  "use_on_type_format": true,
  "enable_language_server": true,
  "active_pane_modifiers": {
    "inactive_opacity": 0.6
  },
  "window_decorations": "server",
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show_tab_bar_buttons": false,
    "show": true
  },
  "toolbar": {
    "selections_menu": false,
    "quick_actions": false,
    "breadcrumbs": false,
    "agent_review": false,
    "code_actions": true
  },
  "gutter": {
    "min_line_number_digits": 3,
    "runnables": false,
    "line_numbers": true,
    "breakpoints": false
  },
  "unnecessary_code_fade": 0.5,
  "buffer_line_height": "comfortable",
  "format_on_save": "off",
  "remove_trailing_whitespace_on_save": false,
  "ensure_final_newline_on_save": false,
  "git": {
    "path_style": "file_name_first",
    "git_gutter": "tracked_files"
  },
  "calls": {
    "mute_on_join": true
  },
  "minimap": {
    "show": "never",
    "thumb": "always",
    "thumb_border": "right_open"
  },
  "scrollbar": {
    "selected_symbol": false,
    "axes": {
      "horizontal": false
    },
    "show": "auto"
  },
  "scroll_sensitivity": 4.0,
  "use_system_prompts": false,
  "use_system_path_prompts": false,
  "icon_theme": "Catppuccin Mocha",
  "soft_wrap": "editor_width",
  "autoscroll_on_clicks": false,
  "agent_ui_font_size": 15.0,
  "fast_scroll_sensitivity": 12.0,
  "vertical_scroll_margin": 18.0,
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "zoomed_padding": false,
  "preview_tabs": {
    "enable_preview_from_multibuffer": false,
    "enable_preview_from_file_finder": true
  },
  "tabs": {
    "show_diagnostics": "all",
    "show_close_button": "hover",
    "file_icons": true,
    "git_status": true
  },
  "title_bar": {
    "show_user_menu": true,
    "show_user_picture": true,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_branch_name": true,
    "show_menus": false,
    "show_sign_in": true,
    "show_branch_icon": true
  },
  "agent": {
    "button": false,
    "model_parameters": []
  },
  "collaboration_panel": {
    "default_width": 300.0,
    "dock": "left",
    "button": true
  },
  "outline_panel": {
    "indent_size": 14.0,
    "default_width": 300.0,
    "folder_icons": false,
    "button": false
  },
  "notification_panel": {
    "button": false
  },
  "git_panel": {
    "default_width": 300.0,
    "tree_view": true,
    "sort_by_path": false,
    "status_style": "label_color",
    "button": true
  },
  "debugger": {
    "button": false
  },
  "search": {
    "button": false
  },
  "diagnostics": {
    "inline": {
      "update_debounce_ms": 150,
      "padding": 4,
      "enabled": true
    },
    "lsp_pull_diagnostics": {
      "enabled": true
    },
    "button": false
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": false
    },
    "dock": "bottom",
    "shell": "system",
    "cursor_shape": "bar",
    "alternate_scroll": "off",
    "button": false
  },
  "project_panel": {
    "indent_size": 14.0,
    "hide_root": true,
    "bold_folder_labels": true,
    "default_width": 300.0,
    "starts_open": false,
    "folder_icons": true,
    "entry_spacing": "comfortable",
    "button": true
  },
  "status_bar": {
    "cursor_position_button": false,
    "active_language_button": true
  },
  "ui_font_family": "Adwaita Sans",
  "buffer_font_family": "Adwaita Mono",
  "disable_ai": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "ui_font_size": 18.0,
  "buffer_font_size": 16.0,
  "theme": "Dracula",
  "file_scan_exclusions": [
    "**/.git",
    "**/.devgamedata",
    "**/.godot",
    "**/.docs",
    "**.ods#"
  ],
}
