// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "(Editor && mode == full)",
    "bindings": {
      "ctrl-o": "outline::Toggle"
    }
  },
  {
    "bindings": {
      "ctrl-shift-o": "workspace::Open"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "enter": "search::SelectNextMatch"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "shift-enter enter": "search::SelectPreviousMatch"
    }
  },
  {
    "context": "ProjectSearchView",
    "bindings": {
      "ctrl-r": "search::ToggleReplace"
    }
  },
  {
    "context": "Editor",
      "bindings": {
      "ctrl-|": "workspace::NewTerminal"
    }
  },
  {
    "context": "(Editor && mode == full)",
      "bindings": {
      "ctrl-g": "git_panel::ToggleFocus"
    }
  },
  {
    "context": "(Editor && mode == full)",
    "bindings": {
      "ctrl-shift-g": "go_to_line::Toggle"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-down": ["editor::MoveDownByLines", {"lines":4}]
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-up": ["editor::MoveUpByLines", {"lines":4}]
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-;": [
        "editor::MoveToBeginningOfLine",
        {
          "stop_at_soft_wraps": true,
          "stop_at_indent": true
        }
      ]
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-'": [
        "editor::MoveToEndOfLine",
        {
          "stop_at_soft_wraps": true
        }
      ]
    }
  },
  {
    "bindings": {
      "alt-v": "workspace::ToggleVimMode"
    }
  },
  {
    "context": "(Editor && mode == full)",
    "bindings": {
      "ctrl-shift-backspace": null
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-shift-backspace": "editor::DeleteLine"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-r": "task::Spawn"
    }
  }
]
